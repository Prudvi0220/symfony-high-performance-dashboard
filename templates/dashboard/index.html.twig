{% extends 'base.html.twig' %}

{% block title %}
   Dashboard
{% endblock %}

{% block body %}

<div class="container">
    <h2>Dashboard Data</h2>
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Title</th>
                <th scope="col">Visits</th>
                <th scope="col">Revenue</th>
            </tr>
        </thead>
        <tbody>
            {% for row in dashboards %}
                <tr>
                    <td>{{ row.id }}</td>
                    <td>{{ row.title }}</td>
                    <td>{{ row.visits }}</td>
                    <td>{{ row.revenue }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <nav aria-label="Dashboard pagination">
        <ul class="pagination">
            <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                <a class="page-link" href="{{ path('dashboard', {page: page - 1}) }}" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>
            {% for p in 1..total_pages %}
                <li class="page-item {{ p == page ? 'active' : '' }}">
                    <a class="page-link" href="{{ path('dashboard', {page: p}) }}">{{ p }}</a>
                </li>
            {% endfor %}
            <li class="page-item {{ page >= total_pages ? 'disabled' : '' }}">
                <a class="page-link" href="{{ path('dashboard', {page: page + 1}) }}" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
</div>

{% endblock %}
